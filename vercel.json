{
  "version": 2,
  "rewrites": [
    { "source": "/resources/:slug", "destination": "/index.html" },
    { "source": "/resources", "destination": "/index.html" },
    { "source": "/free", "destination": "/index.html" },
    { "source": "/premium", "destination": "/index.html" },
    { "source": "/support", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/refunds", "destination": "/index.html" },
    { "source": "/community", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
