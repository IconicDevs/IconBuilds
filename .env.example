# Vercel KV / Upstash REST primary storage
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin API access. Use a long random value, and replace this with real auth later.
ADMIN_API_KEY=
ADMIN_EMAILS=thestickboy@example.com,itzkuroyt@example.com

# Encrypted GitHub backup fallback.
# Token should only have contents read/write for the backup repo.
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=owner/private-backup-repo
GITHUB_BACKUP_BRANCH=main
GITHUB_BACKUP_PATH=iconbuilds/marketplace.encrypted.json
GITHUB_BACKUP_ENCRYPTION_KEY=
